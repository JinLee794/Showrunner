    {
      "type": "code-terminal",
      "duration": 8,
      "transition": "fade",
      "data": {
        "title": "Step 1 — Add the MCP Server",
        "shell": "~/.config/mcp.json",
        "lines": [
          { "kind": "comment", "text": "Register Showrunner in your agent's MCP config:" },
          { "kind": "blank" },
          { "kind": "prompt", "text": "<span class=\"keyword\">{</span>" },
          { "kind": "output", "text": "  <span class=\"string\">\"mcpServers\"</span>: {" },
          { "kind": "output", "text": "    <span class=\"string\">\"showrunner\"</span>: {" },
          { "kind": "output", "text": "      <span class=\"string\">\"command\"</span>: <span class=\"string\">\"node\"</span>," },
          { "kind": "output", "text": "      <span class=\"string\">\"args\"</span>: [<span class=\"string\">\"dist/server.js\"</span>]," },
          { "kind": "output", "text": "      <span class=\"string\">\"transport\"</span>: <span class=\"string\">\"stdio\"</span>" },
          { "kind": "output", "text": "    }" },
          { "kind": "output", "text": "  }" },
          { "kind": "prompt", "text": "<span class=\"keyword\">}</span>" },
          { "kind": "blank" },
          { "kind": "success", "text": "✓ That's it — your agent can now produce videos" }
        ]
      },
      "notes": "Show how trivial setup is"
    },

    {
      "type": "code-terminal",
      "duration": 10,
      "transition": "fade",
      "data": {
        "title": "Step 2 — Prompt Your Agent",
        "shell": "Copilot Chat",
        "lines": [
          { "kind": "comment", "text": "Talk to your agent in natural language:" },
          { "kind": "blank" },
          { "kind": "prompt", "text": "Create a 45-second video recap of our sprint." },
          { "kind": "prompt", "text": "Show KPIs, a burndown chart, top risks, and action items." },
          { "kind": "prompt", "text": "Use the microsoft theme." },
          { "kind": "blank" },
          { "kind": "comment", "text": "The agent discovers scene types, builds a storyboard, then renders:" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "→ <span class=\"accent\">list_scene_types</span>  ← discover what's available" },
          { "kind": "highlight", "text": "→ <span class=\"accent\">validate_storyboard</span>  ← dry-run check" },
          { "kind": "success", "text": "  ✓ Valid — 8 scenes, 44s, 1320 frames" },
          { "kind": "highlight", "text": "→ <span class=\"accent\">render_video</span>  ← full render pipeline" },
          { "kind": "output", "text": "  ⠋ Rendering scene 1/8: title-card ..." },
          { "kind": "output", "text": "  ⠙ Rendering scene 4/8: chart-bar ..." },
          { "kind": "output", "text": "  ⠸ Encoding H.264 MP4 ..." },
          { "kind": "blank" },
          { "kind": "success", "text": "  ✓ Done — <span class=\"string\">/output/sprint-recap.mp4</span>" },
          { "kind": "success", "text": "    44s | 1320 frames | 2.1 MB" }
        ]
