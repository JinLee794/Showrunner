    {
      "type": "code-terminal",
      "duration": 9,
      "transition": "fade",
      "data": {
        "title": "Building a Storyboard Programmatically",
        "shell": "node",
        "lines": [
          { "kind": "comment", "text": "Use the SDK to build storyboards in your agent:" },
          { "kind": "blank" },
          { "kind": "prompt", "text": "<span class=\"keyword\">import</span> { StoryboardSchema } <span class=\"keyword\">from</span> <span class=\"string\">'showrunner'</span>;" },
          { "kind": "blank" },
          { "kind": "prompt", "text": "<span class=\"keyword\">const</span> storyboard = StoryboardSchema.<span class=\"accent\">parse</span>({" },
          { "kind": "output", "text": "  title: <span class=\"string\">'Q2 Pipeline Review'</span>," },
          { "kind": "output", "text": "  theme: <span class=\"string\">'microsoft'</span>," },
          { "kind": "output", "text": "  scenes: [" },
          { "kind": "output", "text": "    { type: <span class=\"string\">'title-card'</span>, duration: <span class=\"number\">5</span>, data: { ... } }," },
          { "kind": "output", "text": "    { type: <span class=\"string\">'chart-bar'</span>, duration: <span class=\"number\">7</span>, data: { ... } }," },
          { "kind": "output", "text": "    { type: <span class=\"string\">'kpi-scorecard'</span>, duration: <span class=\"number\">6</span>, data: { ... } }," },
          { "kind": "output", "text": "  ]" },
          { "kind": "output", "text": "});" },
          { "kind": "blank" },
          { "kind": "success", "text": "✓ Zod validates every field — type-safe at build time" }
        ]
      },
      "notes": "Show the programmatic API with syntax highlighting"
    },

    {
      "type": "code-terminal",
      "duration": 8,
      "transition": "fade",
      "data": {
        "title": "The Rendering Pipeline — Under the Hood",
        "shell": "showrunner internals",
        "lines": [
          { "kind": "comment", "text": "What happens when you call render_video:" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "1. <span class=\"accent\">Parse</span> — Validate storyboard against Zod schema" },
          { "kind": "highlight", "text": "2. <span class=\"accent\">Resolve</span> — Load theme CSS + HTML templates + GSAP bundle" },
          { "kind": "highlight", "text": "3. <span class=\"accent\">Pool</span> — Acquire warm Chromium from browser pool" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "4. <span class=\"accent\">For each scene:</span>" },
          { "kind": "output", "text": "   → Inject data into Handlebars template" },
          { "kind": "output", "text": "   → Scene JS builds a <span class=\"accent\">paused GSAP timeline</span>" },
          { "kind": "output", "text": "   → For each frame: <span class=\"keyword\">window.__seek(t)</span>" },
          { "kind": "output", "text": "   → GSAP scrubs all animations to time t" },
          { "kind": "output", "text": "   → Playwright captures screenshot → PNG frame" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "5. <span class=\"accent\">Encode</span> — ffmpeg assembles frames → H.264 MP4" },
          { "kind": "highlight", "text": "6. <span class=\"accent\">Return</span> — { path, duration, frames, fileSize }" },
          { "kind": "blank" },
          { "kind": "success", "text": "✓ Deterministic — same input always produces same output" }
        ]
      },
      "notes": "Technical deep-dive into the architecture"
    },

