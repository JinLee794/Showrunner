  "fps": 30,
  "resolution": [1920, 1080],
  "scenes": [
    {
      "type": "title-card",
      "duration": 5,
      "transition": "fade",
      "data": {
        "title": "Showrunner",
        "subtitle": "Turn structured data into polished MP4s — no editor, no templates, no subscriptions",
