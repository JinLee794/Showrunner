    {
      "type": "section-header",
      "duration": 3,
      "transition": "slide-left",
      "data": {
        "heading": "Under the Hood",
        "subheading": "Playwright + GSAP timelines + ffmpeg"
      }
    },
    {
      "type": "code-terminal",
      "duration": 9,
      "transition": "fade",
      "data": {
        "title": "The Render Pipeline",
        "shell": "showrunner",
        "lines": [
          { "kind": "comment", "text": "What happens when render_video is called:" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "1. <span class=\"accent\">Validate</span> storyboard against Zod schema" },
          { "kind": "highlight", "text": "2. <span class=\"accent\">Resolve</span> theme CSS + scene HTML templates + GSAP bundle" },
          { "kind": "highlight", "text": "3. <span class=\"accent\">Acquire</span> warm Playwright browser from pool" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "4. For each scene:" },
          { "kind": "output", "text": "   Build HTML page → inject theme + GSAP + scene data" },
          { "kind": "output", "text": "   Scene JS builds a <span class=\"accent\">paused GSAP timeline</span>" },
          { "kind": "output", "text": "   For each frame: <span class=\"keyword\">window.__seek(progress)</span>" },
          { "kind": "output", "text": "   GSAP scrubs all animations to that point" },
          { "kind": "output", "text": "   Playwright captures screenshot → frame saved" },
          { "kind": "blank" },
          { "kind": "highlight", "text": "5. <span class=\"accent\">ffmpeg</span> encodes frames → H.264 MP4" },
          { "kind": "highlight", "text": "6. Return <span class=\"string\">{ path, duration, frames, fileSize }</span>" },
          { "kind": "blank" },
          { "kind": "success", "text": "✓ Deterministic — same input always produces same video" }
        ]
      }
    },

    {
      "type": "section-header",
      "duration": 3,
      "transition": "slide-left",
      "data": {
        "heading": "The Full Tool Surface",
        "subheading": "Five MCP tools — discover, validate, preview, render"
      }
    },
    {
      "type": "table",
      "duration": 7,
      "transition": "fade",
      "data": {
        "title": "MCP Tools",
        "columns": [
          { "key": "tool", "label": "Tool", "width": "30%" },
          { "key": "purpose", "label": "Purpose", "width": "45%" },
          { "key": "output", "label": "Output", "width": "25%" }
        ],
        "rows": [
          { "tool": "list_scene_types", "purpose": "Discover available scene types + schemas", "output": "JSON array" },
          { "tool": "validate_storyboard", "purpose": "Dry-run validation", "output": "Errors / summary" },
          { "tool": "preview_storyboard", "purpose": "Instant HTML preview (no ffmpeg)", "output": "HTML file" },
          { "tool": "render_scene", "purpose": "Single scene → MP4 or GIF", "output": "MP4 / GIF" },
          { "tool": "render_video", "purpose": "Full storyboard → MP4", "output": "MP4 file" }
        ],
        "highlightRows": [4]
      }
    },

    {
      "type": "comparison",
      "duration": 6,
