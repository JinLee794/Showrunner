          { "name": "Pipeline Funnel", "description": "Bars grow left-to-right with staggered spring easing", "icon": "📊", "style": "funnel" },
          { "name": "KPI Scorecard", "description": "Numbers count up from zero with trend arrows", "icon": "📈", "style": "kpi" },
          { "name": "Risk Callout", "description": "Cards slide in with severity color coding", "icon": "⚠️", "style": "risk" },
