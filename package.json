{
  "name": "showrunner",
  "version": "0.1.0",
  "description": "MCP server for programmatic video generation — storyboard JSON in, MP4 out.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates && cp -r src/themes dist/themes",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "d3": "^7.9.0",
    "express": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "gsap": "^3.12.7",
    "handlebars": "^4.7.8",
    "playwright": "^1.50.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
