{
  "name": "@jinlee794/showrunner-mcp",
  "version": "0.3.1",
  "description": "MCP server for programmatic video generation — storyboard JSON in, MP4 out.",
  "type": "module",
  "main": "dist/server.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "showrunner": "dist/cli.js",
    "showrunner-mcp": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/templates dist/themes && cp -r src/templates dist/templates && cp -r src/themes dist/themes",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright install chromium 2>/dev/null || true",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest",
    "generate:catalog": "npx tsx scripts/generate-scene-catalog.ts",
    "generate:catalog:md-only": "npx tsx scripts/generate-scene-catalog.ts --skip-gifs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "video",
    "mp4",
    "gif",
    "storyboard",
    "animation",
    "gsap",
    "d3",
    "playwright",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JinLee794/Showrunner.git"
  },
  "homepage": "https://github.com/JinLee794/Showrunner#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "d3": "^7.9.0",
    "gsap": "^3.12.7",
    "handlebars": "^4.7.8",
    "playwright": "^1.50.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.15.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
